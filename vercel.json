{
  "crons": [
    {
      "path": "/api/recalcul-stats",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/monthly-badge",
      "schedule": "0 6 1 * *"
    },
    {
      "path": "/api/cron/wrap-mensuel",
      "schedule": "0 9 2 * *"
    },
    {
      "path": "/api/cron/weekly-post",
      "schedule": "0 10 * * 0"
    }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).(ico|png|jpg|jpeg|svg|webp)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }]
    }
  ]
}
